# Klicklocal frontend — PRODUCTION (deploys from `main` branch)
# Customer app: https://klicklocal.app   Admin: https://admin.klicklocal.app
# Copy values into your host / Vercel Project → Settings → Environment Variables.
# Repo: https://github.com/emretokatli/klicklocal

# --- Option A (recommended): Next.js proxy — avoids browser CORS ---
NEXT_PUBLIC_API_URL=/api/v1
BACKEND_API_URL=https://api.klicklocal.app/api/v1
NEXT_PUBLIC_STORAGE_URL=https://api.klicklocal.app/storage

# --- Option B: browser calls Laravel directly (add the app origin to backend CORS_ALLOWED_ORIGINS) ---
# NEXT_PUBLIC_API_URL=https://api.klicklocal.app/api/v1
# NEXT_PUBLIC_STORAGE_URL=https://api.klicklocal.app/storage
